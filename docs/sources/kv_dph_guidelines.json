  "sections": [
    {
      "id": "A1",
      "name_sk": "Faktúry vydané — štandardné tuzemské dodávky",
      "name_en": "Invoices issued — standard domestic supplies",
      "side": "supplier",
      "type": "output_vat",
      "reporting_style": "individual",
      "classification_criteria": [
        "Invoice issued by the VAT payer (supplier)",
        "Supply of goods or services with place of supply in Slovakia",
        "Supplier is liable for VAT (standard case under §69 ods. 1)",
        "Customer has IČ DPH or IČO",
        "Does NOT include supplies to private individuals (those go to D.2)",
        "Does NOT include reverse charge supplies (those go to A.2)",
        "Includes specified goods under §69(12)(f-i) where tax base per invoice < 5,000 EUR"
      ],
      "required_fields": [
        {"field": "ic_dph_odberatela", "label_sk": "IČ DPH odberateľa", "label_en": "Customer VAT ID", "type": "string"},
        {"field": "poradove_cislo_faktury", "label_sk": "Poradové číslo faktúry", "label_en": "Invoice sequential number", "type": "string"},
        {"field": "datum_dodania", "label_sk": "Dátum dodania tovaru/služby", "label_en": "Date of supply", "type": "date"},
        {"field": "zaklad_dane", "label_sk": "Základ dane", "label_en": "Tax base", "type": "decimal"},
        {"field": "suma_dane", "label_sk": "Suma dane", "label_en": "VAT amount", "type": "decimal"},
        {"field": "sadzba_dane", "label_sk": "Sadzba dane", "label_en": "VAT rate", "type": "decimal"},
        {"field": "kod_opravy", "label_sk": "Kód opravy", "label_en": "Correction code", "type": "integer", "nullable": true}
      ],
      "examples": [
        {
          "description": "Standard domestic service invoice",
          "scenario": "Company ABC s.r.o. issues invoice #2025001 for consulting to XY s.r.o.",
          "data": {
            "ic_dph_odberatela": "SK1234567890",
            "poradove_cislo_faktury": "2025001",
            "datum_dodania": "2025-03-15",
            "zaklad_dane": 1000.00,
            "suma_dane": 230.00,
            "sadzba_dane": 23,
            "total_invoice": 1230.00
          },
          "section": "A1",
          "reasoning": "Standard domestic supply, supplier charges VAT, customer has VAT ID"
        },
        {
          "description": "Specified goods below reverse charge threshold",
          "scenario": "Supplier sells mobile phones to retailer, tax base 3,000 EUR (below 5,000 EUR threshold)",
          "data": {
            "ic_dph_odberatela": "SK9876543210",
            "poradove_cislo_faktury": "2025050",
            "datum_dodania": "2025-03-20",
            "zaklad_dane": 3000.00,
            "suma_dane": 690.00,
            "sadzba_dane": 23,
            "total_invoice": 3690.00
          },
          "section": "A1",
          "reasoning": "Mobile phones but tax base < 5,000 EUR, so no reverse charge — standard A.1"
        }
      ],
      "special_cases": [
        "If invoice date differs from supply date, use supply date for period assignment",
        "Missing supply date: use invoice issuance date as supply date"
      ]
    },
    {
      "id": "A2",
      "name_sk": "Faktúry vydané — tuzemský prenos daňovej povinnosti",
      "name_en": "Invoices issued — domestic reverse charge (supplier side)",
      "side": "supplier",
      "type": "reverse_charge_output",
      "reporting_style": "individual",
      "threshold": {
        "amount": 5000,
        "currency": "EUR",
        "applies_to": "tax_base_per_invoice",
        "applies_to_goods": ["agricultural_products", "metals", "mobile_phones", "integrated_circuits"],
        "note": "Threshold applies to §69(12)(f-i) goods only. Construction works §69(12)(j) have NO threshold."
      },
      "classification_criteria": [
        "Invoice issued by the supplier",
        "Recipient bears VAT liability under §69 ods. 12 písm. f) to j)",
        "For goods under §69(12)(f-i): tax base per invoice >= 5,000 EUR",
        "For construction works under §69(12)(j): always, regardless of amount",
        "Supplier does NOT charge VAT — only tax base reported"
      ],
      "reverse_charge_categories": [
        {"paragraph": "§69(12)(f)", "category": "agricultural_products", "label_sk": "Poľnohospodárske plodiny", "threshold_eur": 5000, "commodity_code_required": true},
        {"paragraph": "§69(12)(g)", "category": "metals", "label_sk": "Kovy a kovové výrobky", "threshold_eur": 5000, "commodity_code_required": true},
        {"paragraph": "§69(12)(h)", "category": "mobile_phones", "label_sk": "Mobilné telefóny", "threshold_eur": 5000, "commodity_code_required": false, "goods_type_required": true},
        {"paragraph": "§69(12)(i)", "category": "integrated_circuits", "label_sk": "Integrované obvody", "threshold_eur": 5000, "commodity_code_required": false, "goods_type_required": true},
        {"paragraph": "§69(12)(j)", "category": "construction_works", "label_sk": "Stavebné práce (CPA divízia F)", "threshold_eur": null, "commodity_code_required": false, "note": "No threshold — always reverse charge"}
      ],
      "required_fields": [
        {"field": "ic_dph_odberatela", "label_sk": "IČ DPH odberateľa", "label_en": "Customer VAT ID", "type": "string"},
        {"field": "poradove_cislo_faktury", "label_sk": "Poradové číslo faktúry", "label_en": "Invoice sequential number", "type": "string"},
        {"field": "datum_dodania", "label_sk": "Dátum dodania", "label_en": "Date of supply", "type": "date"},
        {"field": "zaklad_dane", "label_sk": "Základ dane", "label_en": "Tax base", "type": "decimal"},
        {"field": "kod_tovaru", "label_sk": "Kód tovaru", "label_en": "Commodity code", "type": "string", "nullable": true, "required_for": ["agricultural_products", "metals"]},
        {"field": "druh_tovaru", "label_sk": "Druh tovaru", "label_en": "Goods type", "type": "string", "nullable": true, "required_for": ["mobile_phones", "integrated_circuits"]},
        {"field": "mnozstvo", "label_sk": "Množstvo", "label_en": "Quantity", "type": "decimal"},
        {"field": "merna_jednotka", "label_sk": "Merná jednotka", "label_en": "Unit of measure", "type": "string"},
        {"field": "kod_opravy", "label_sk": "Kód opravy", "label_en": "Correction code", "type": "integer", "nullable": true}
      ],
      "examples": [
        {
          "description": "Mobile phones above reverse charge threshold",
          "scenario": "Telefonujeme s.r.o. supplies 400 mobile phones to Volám s.r.o. for 10,000 EUR tax base",
          "data": {
            "ic_dph_odberatela": "SK9865389560",
            "poradove_cislo_faktury": "2025100",
            "datum_dodania": "2025-04-01",
            "zaklad_dane": 10000.00,
            "druh_tovaru": "mobile_phones",
            "mnozstvo": 400,
            "merna_jednotka": "ks"
          },
          "section": "A2",
          "reasoning": "Mobile phones, tax base 10,000 EUR >= 5,000 EUR threshold → reverse charge applies"
        },
        {
          "description": "Construction works — no threshold",
          "scenario": "Construction company issues invoice for building renovation, 8,000 EUR tax base",
          "data": {
            "ic_dph_odberatela": "SK1122334455",
            "poradove_cislo_faktury": "2025200",
            "datum_dodania": "2025-04-15",
            "zaklad_dane": 8000.00
          },
          "section": "A2",
          "reasoning": "CPA F construction work — always reverse charge, no threshold"
        }
      ],
      "special_cases": [
        "No VAT amount on the invoice — supplier does not charge VAT in reverse charge",
        "Combined invoice for multiple commodity types: each commodity category evaluated separately against 5,000 EUR threshold",
        "Construction works: no threshold applies, always A.2"
      ]
    },
    {
